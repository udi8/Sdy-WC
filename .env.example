# ── Firebase ────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── football-data.org (free tier) ───────────────────────────
# Register at https://www.football-data.org/
VITE_FOOTBALL_DATA_API_KEY=your_football_data_key

# ── API-Football (100 calls/day) ─────────────────────────────
# Register at https://www.api-football.com/ (RapidAPI)
VITE_API_FOOTBALL_KEY=your_api_football_key
